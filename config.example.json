{
  "server": {
    "host": "127.0.0.1",
    "port": 3000,
    "workers": 8
  },
  "admin": {
    "host": "127.0.0.1",
    "port": 3001,
    "base_url": null,
    "allow_public_registration": false
  },
  "database": {
    "path": "data/modelproxy.db",
    "max_connections": 10
  },
  "jwt": {
    "secret": "<change-me-to-a-secure-random-string>",
    "expiration_hours": 0,
    "upstream_key_secret": "<optional-separate-secret-for-encrypting-upstream-keys>"
  },
  "proxy": {
    "request_timeout_secs": 300,
    "connect_timeout_secs": 30,
    "max_idle_connections": 200,
    "max_request_body_bytes": 33554432,
    "max_text_request_body_bytes": 2097152,
    "max_multimodal_request_body_bytes": 20971520
  },
  "rate_limit": {
    "cleanup_interval_secs": 60,
    "window_size_secs": 60
  }
}
