        <!-- ===== 侧边说明 ===== -->
        <mxCell id="note1" value="条件路由匹配规则：&lt;br&gt;① 输入文本的估算字数&lt;br&gt;   是否在指定范围内&lt;br&gt;② 请求文本是否包含&lt;br&gt;   指定关键词&lt;br&gt;③ 当前时间是否在&lt;br&gt;   指定时段内&lt;br&gt;④ 请求用户是否有权使用" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;align=left;spacingLeft=5;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="30" y="530" width="170" height="120" as="geometry" />
        </mxCell>

        <mxCell id="note2" value="重试等待策略：&lt;br&gt;① 固定间隔：每次等相同时间&lt;br&gt;② 递增间隔：每次等待时间翻倍&lt;br&gt;③ 递增+随机：翻倍后加随机抖动" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;align=left;spacingLeft=5;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1490" width="170" height="90" as="geometry" />
        </mxCell>

        <mxCell id="note3" value="后备模型优先级：&lt;br&gt;当前模型失败后，&lt;br&gt;先走它自己配置的后备链，&lt;br&gt;后备链走完才轮到&lt;br&gt;队列里的其他候选" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;align=left;spacingLeft=5;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1600" width="170" height="90" as="geometry" />
        </mxCell>

        <mxCell id="note4" value="防循环机制：&lt;br&gt;如果后备模型之前&lt;br&gt;已经尝试过并失败，&lt;br&gt;不会重复加入队列" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;align=left;spacingLeft=5;spacingTop=5;" vertex="1" parent="1">
